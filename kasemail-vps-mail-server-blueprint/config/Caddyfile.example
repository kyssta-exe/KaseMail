# Replace hostnames before production.
panel.example.com {
  encode zstd gzip
  reverse_proxy panel:3000
}

webmail.example.com {
  encode zstd gzip
  reverse_proxy panel:3000
}

mta-sts.example.com {
  respond /.well-known/mta-sts.txt "version: STSv1\nmode: testing\nmx: mail.example.com\nmax_age: 86400\n" 200
}
