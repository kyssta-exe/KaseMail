generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  WORKSPACE_ADMIN
  WORKSPACE_USER
  INDIVIDUAL_USER
}

enum RegistrationMode {
  CLOSED
  INVITE_ONLY
  REQUEST_ACCESS
  PUBLIC_DISABLED
}

enum DomainStatus {
  CREATED
  AWAITING_OWNERSHIP
  DNS_PENDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum MailboxStatus {
  CREATED
  ACTIVE
  SUSPENDED
  ARCHIVED
  DELETED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  role         Role     @default(WORKSPACE_USER)
  twoFactorOn  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  memberships  WorkspaceMember[]
  auditLogs    AuditLog[] @relation("ActorAuditLogs")
}

model Workspace {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  type             String   @default("team")
  registrationMode RegistrationMode @default(CLOSED)
  defaultQuotaMb   Int      @default(10240)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  members          WorkspaceMember[]
  domains          Domain[]
  mailboxes        Mailbox[]
  aliases          Alias[]
}

model WorkspaceMember {
  id          String @id @default(cuid())
  workspaceId String
  userId      String
  role        Role
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  user        User @relation(fields: [userId], references: [id])
  @@unique([workspaceId, userId])
}

model Domain {
  id              String @id @default(cuid())
  workspaceId     String
  name            String @unique
  status          DomainStatus @default(CREATED)
  verificationTxt String
  dkimSelector    String?
  dkimPublicKey   String?
  catchAllMailboxId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  mailboxes       Mailbox[]
  aliases         Alias[]
  dnsChecks       DnsCheck[]
}

model DnsCheck {
  id        String @id @default(cuid())
  domainId  String
  type      String
  host      String
  expected  String
  actual    String?
  status    String
  checkedAt DateTime @default(now())
  domain    Domain @relation(fields: [domainId], references: [id])
}

model Mailbox {
  id          String @id @default(cuid())
  workspaceId String
  domainId    String
  localPart   String
  address     String @unique
  status      MailboxStatus @default(CREATED)
  quotaMb     Int @default(10240)
  mailCoreId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  domain      Domain @relation(fields: [domainId], references: [id])
}

model Alias {
  id          String @id @default(cuid())
  workspaceId String
  domainId    String
  address     String @unique
  targets     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  domain      Domain @relation(fields: [domainId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  workspaceId String?
  action      String
  targetType  String
  targetId    String?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User? @relation("ActorAuditLogs", fields: [actorUserId], references: [id])
}

model MailMigrationJob {
  id          String @id @default(cuid())
  workspaceId String
  mailboxId   String
  sourceHost  String
  sourceUser  String
  status      String
  progress    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BackupJob {
  id        String @id @default(cuid())
  status    String
  target    String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  metadata  Json?
}
